{
  "hyprland/workspaces": {
    "active-only": false,
    "all-outputs": true,
    "on-click": "activate",
  },

  "hyprland/window": {
    "format": "{title}",
    "icon": false,
    "separate-outputs": true,
    "rewrite": {
      "(.*) - Google Chrome": "$1", // chrome
    }
  },

  "pulseaudio": {
      "format": "{icon}  {volume}%",
      "format-muted": "",
      "format-icons": {
          "default": ["", "", " "]
      },
      "scroll-step": 1,
      "on-click": "pavucontrol"
  },

  "clock": {
    "format": "<span foreground='#f5c2e7'>  </span>{:%a %d %H:%M}",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
    "on-click": "google-chrome-stable https://calendar.google.com/calendar/u/0/r?pli=1"
  },

  "custom/wlogout": {
    "format" : "⏻",
    "tooltip": false,
    "on-click": "wlogout --protocol layer-shell"
  },
}
